{
  "name": "mawu",
  "version": "1.0.0",
  "description": "码悟 - 极简AI代码编辑器",
  "main": "./out/main/index.js",
  "author": "MaWu",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.mawu.editor",
    "productName": "码悟",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "shortcutName": "码悟",
      "artifactName": "码悟-Setup-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64",
            "armv7l",
            "ia32"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64",
            "armv7l",
            "ia32"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "category": "Development",
      "artifactName": "码悟-${version}-linux-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "category": "public.app-category.developer-tools",
      "artifactName": "码悟-${version}-mac-${arch}.${ext}"
    }
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "fs-extra": "^11.2.0",
    "iconv-lite": "^0.7.2",
    "simple-git": "^3.24.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/iconv-lite": "^0.0.1",
    "@vitejs/plugin-vue": "^5.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "monaco-editor": "^0.50.0",
    "pinia": "^2.1.7",
    "png2icons": "^2.0.1",
    "tdesign-vue-next": "^1.10.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vue": "^3.4.0",
    "vue-router": "^4.4.0"
  }
}
